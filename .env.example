NMRXIV_BASE_URL=https://nmrxiv.org
NMRXIV_EMAIL=your.email@example.com
NMRXIV_PASSWORD=your-password

# Values from a signed email verification URL.
NMRXIV_VERIFY_EXPIRES=
NMRXIV_VERIFY_SIGNATURE=

# Registration creates a real account. Keep false unless you intentionally test it.
NMRXIV_RUN_REGISTRATION=false

# ELN submission creates/updates drafts. Keep false unless intentionally testing.
NMRXIV_ELN=chemotion
NMRXIV_ELN_CALLBACK_URL=https://chemotion.example.com/api/callback
NMRXIV_RUN_ELN_UPLOAD=false
NMRXIV_RUN_ELN_STATUS=false
